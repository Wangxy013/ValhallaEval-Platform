# EditorConfig is awesome: https://EditorConfig.org

# ── Root ──────────────────────────────────────────────────────────────────────
root = true

# ── General ───────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ── Markdown ─────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ── Rust ─────────────────────────────────────────────────────────────────────
[*.rs]
indent_style = space
indent_size = 4

# ── TypeScript / React ───────────────────────────────────────────────────────
[*.{ts,tsx}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

# ── YAML ─────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ── Shell ─────────────────────────────────────────────────────────────────────
[*.sh]
indent_style = space
indent_size = 2

# ── Nginx ────────────────────────────────────────────────────────────────────
[*.conf]
indent_style = space
indent_size = 2

# ── Dockerfile ───────────────────────────────────────────────────────────────
[Dockerfile*]
indent_style = space
indent_size = 4
